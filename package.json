{
  "name": "@maxed-oss/maxed-ui",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "A lightweight TypeScript + React component kit for building accounting and bookkeeping UIs.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxed-oss/maxed-ui.git"
  },
  "homepage": "https://github.com/maxed-oss/maxed-ui#readme",
  "bugs": {
    "url": "https://github.com/maxed-oss/maxed-ui/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "react",
    "typescript",
    "accounting",
    "bookkeeping",
    "ledger",
    "components",
    "ui"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.4.6",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^4.1.9"
  }
}
